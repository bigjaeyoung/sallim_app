# M2 active — point the mobile app at your API.
#
# Local dev: use your Mac's LAN IP (NOT localhost) so Expo Go on your phone
# can reach it. Find it: `ipconfig getifaddr en0` on macOS.
# Example:
EXPO_PUBLIC_API_URL=http://192.168.0.10:4000

# Production (Railway):
# EXPO_PUBLIC_API_URL=https://api.sallim.app

# ===== M9+ (analytics + errors) =====
# EXPO_PUBLIC_POSTHOG_KEY=phc_...
# EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# EXPO_PUBLIC_SENTRY_DSN=
