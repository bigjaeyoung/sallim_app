# M2 active — Postgres + JWT + Twilio Verify must all be set.

PORT=4000
NODE_ENV=development

# ===== M2 (auth, DB) =====
# Neon Postgres connection strings.
# DATABASE_URL = pooled (used by the app at runtime via Prisma).
# DIRECT_DATABASE_URL = direct (used by Prisma migrations).
# Get both from https://console.neon.tech → your project → Connection Details.
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DIRECT_DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# 32+ random chars. Generate: `openssl rand -base64 48`
JWT_SECRET=change_me_long_random_string_at_least_32_chars

# Twilio Verify (https://console.twilio.com).
# Create a Verify Service first; the SID starts with "VA".
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_VERIFY_SERVICE_SID=VA...

# ===== M4+ (vision) =====
# ANTHROPIC_API_KEY=sk-ant-...

# ===== M4+ (storage) =====
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=sallim-photos

# ===== M5+ (push) =====
# EXPO_ACCESS_TOKEN=

# ===== M6+ (email integration) =====
# GOOGLE_OAUTH_CLIENT_ID=...
# GOOGLE_OAUTH_CLIENT_SECRET=...
# GOOGLE_OAUTH_REDIRECT_URI=https://api.sallim.app/oauth/google/callback
# SEALED_BOX_PUBLIC_KEY=base64...
# SEALED_BOX_PRIVATE_KEY=base64...

# ===== M9+ (billing, errors) =====
# APPLE_SHARED_SECRET=
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=./google-service-account.json
# SENTRY_DSN=
# POSTHOG_API_KEY=
