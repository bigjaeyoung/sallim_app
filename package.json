{
  "name": "sallim-app",
  "version": "0.1.0",
  "private": true,
  "description": "살림 (Sallim) — Korean home product vault. Mobile + API monorepo.",
  "type": "module",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "lint": "pnpm -r run lint",
